{
  "manifest_version": 3,
  "name": "Smart Shopping Assistant",
  "version": "1.0",
  "description": "Find the original store for fashion items.",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  }
}