{
  "manifest_version": 3,
  "name": "Adidas Price Checker",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.adidas.co.il/*"],
      "js": ["content.js"]
    }
  ]
}